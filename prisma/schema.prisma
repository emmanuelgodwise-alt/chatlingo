generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  phone             String?
  password          String
  preferredLanguage String   @default("English")
  learningLanguages String   @default("[]")
  avatar            String?
  bio               String?
  online            Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  contacts          Contact[]           @relation("UserContacts")
  contactOf         Contact[]           @relation("ContactUser")
  conversations1    Conversation[]      @relation("Participant1")
  conversations2    Conversation[]      @relation("Participant2")
  messages          Message[]
  statuses          Status[]            @relation("StatusOwner")
  statusViews       StatusView[]        @relation("StatusViewer")
  groupMemberships  GroupMember[]
  ownedGroups       Group[]             @relation("GroupOwner")
  channelMemberships ChannelMember[]
  ownedChannels     Channel[]           @relation("ChannelOwner")
  channelPosts      ChannelPost[]
  broadcastLists    BroadcastList[]     @relation("BroadcastOwner")
  roomParticipants  RoomParticipant[] @relation("RoomUser")
  ownedRooms        Room[]              @relation("RoomOwner")
  learningProfiles  LearningProfile[]
  learningPairs1    LearningPair[]      @relation("PairLearner")
  learningPairs2    LearningPair[]      @relation("PairTutor")
  lessonProgress    LessonProgress[]
  exerciseAttempts  ExerciseAttempt[]
}

model Contact {
  id            String   @id @default(cuid())
  userId        String
  contactUserId String
  createdAt     DateTime @default(now())

  user        User @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contactUser User @relation("ContactUser", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([userId, contactUserId])
}

model Conversation {
  id               String   @id @default(cuid())
  isGroup          Boolean  @default(false)
  groupId          String?
  participant1Id   String
  participant2Id   String
  participant1Lang String   @default("English")
  participant2Lang String   @default("English")
  lastMessage      String?
  lastMessageAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  participant1 User           @relation("Participant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User           @relation("Participant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  group        Group?         @relation("GroupConversation", fields: [groupId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id])
}

model Message {
  id                String   @id @default(cuid())
  conversationId    String
  senderId          String
  content           String
  translatedContent String?
  senderLanguage    String
  receiverLanguage  String
  read              Boolean  @default(false)
  messageType       String   @default("text")
  voiceUrl          String?
  voiceDuration     Int?
  mediaUrl          String?
  mediaType         String?
  replyToId         String?
  createdAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReply", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReply")
}

model Status {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mediaUrl  String?
  mediaType String   @default("text")
  language  String   @default("English")
  bgGradient String  @default("from-emerald-500 to-teal-600")
  createdAt DateTime @default(now())
  expiresAt DateTime

  owner  User          @relation("StatusOwner", fields: [userId], references: [id], onDelete: Cascade)
  views  StatusView[]
}

model StatusView {
  id        String   @id @default(cuid())
  statusId  String
  viewerId  String
  createdAt DateTime @default(now())

  status Status @relation(fields: [statusId], references: [id], onDelete: Cascade)
  viewer User   @relation("StatusViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([statusId, viewerId])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User           @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       GroupMember[]
  conversations Conversation[] @relation("GroupConversation")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member")
  language  String   @default("English")
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Channel {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  avatar      String?
  language    String   @default("English")
  isPublic    Boolean  @default(true)
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User            @relation("ChannelOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  ChannelMember[]
  posts    ChannelPost[]
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  language  String   @default("English")
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model ChannelPost {
  id          String   @id @default(cuid())
  channelId   String
  authorId    String
  title       String?
  content     String
  translatedContent String?
  mediaUrl    String?
  mediaType   String?
  language    String   @default("English")
  likes       Int      @default(0)
  createdAt   DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model BroadcastList {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner    User            @relation("BroadcastOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  BroadcastMember[]
}

model BroadcastMember {
  id              String   @id @default(cuid())
  broadcastListId String
  userId          String
  language        String   @default("English")

  broadcastList BroadcastList @relation(fields: [broadcastListId], references: [id], onDelete: Cascade)
  @@unique([broadcastListId, userId])
}

model Room {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  language    String   @default("English")
  isLive      Boolean  @default(false)
  speakerCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User               @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  participants RoomParticipant[]
}

model RoomParticipant {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  role      String   @default("listener")
  language  String   @default("English")
  isMuted   Boolean  @default(false)
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation("RoomUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model CulturalSpotlight {
  id          String   @id @default(cuid())
  title       String
  content     String
  language    String
  culture     String
  authorId    String?
  mediaUrl    String?
  createdAt   DateTime @default(now())
}

// ==========================================
// Language Exchange Learning System
// ==========================================

model LearningProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  targetLanguage  String
  nativeLanguage  String
  level           Int      @default(1)
  totalXp         Int      @default(0)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  lastPracticeAt  DateTime?
  lessonsCompleted Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningPair {
  id              String   @id @default(cuid())
  learnerId       String
  tutorId         String
  learnerLanguage String
  tutorLanguage   String
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learner         User     @relation("PairLearner", fields: [learnerId], references: [id], onDelete: Cascade)
  tutor           User     @relation("PairTutor", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([learnerId, tutorId])
}

model Lesson {
  id              String   @id @default(cuid())
  title           String
  description     String?
  category        String   @default("vocabulary")
  targetLanguage  String
  nativeLanguage  String
  level           Int      @default(1)
  orderIndex      Int      @default(0)
  xpReward        Int      @default(10)
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())

  exercises       Exercise[]
  progress        LessonProgress[]
}

model Exercise {
  id              String   @id @default(cuid())
  lessonId        String
  type            String   @default("translation")
  question        String
  correctAnswer   String
  options         String   @default("[]")
  hint            String?
  audioUrl        String?
  orderIndex      Int      @default(0)
  xpReward        Int      @default(5)
  createdAt       DateTime @default(now())

  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts        ExerciseAttempt[]
}

model LessonProgress {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  completed       Boolean  @default(false)
  score           Int      @default(0)
  totalExercises  Int      @default(0)
  bestScore       Int      @default(0)
  attempts        Int      @default(0)
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exerciseAttempts ExerciseAttempt[]

  @@unique([userId, lessonId])
}

model ExerciseAttempt {
  id              String   @id @default(cuid())
  userId          String
  exerciseId      String
  lessonProgressId String
  userAnswer      String
  isCorrect       Boolean  @default(false)
  xpEarned        Int      @default(0)
  createdAt       DateTime @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise        Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  lessonProgress  LessonProgress @relation(fields: [lessonProgressId], references: [id], onDelete: Cascade)
}
